const DB = {
  get: (k, fallback = null) => {
    try { const v = localStorage.getItem("aw_" + k); return v ? JSON.parse(v) : fallback; } catch { return fallback; }
  },
  set: (k, v) => { try { localStorage.setItem("aw_" + k, JSON.stringify(v)); } catch {} },
  del: (k) => { try { localStorage.removeItem("aw_" + k); } catch {} },
};

