const today = () => new Date().toISOString().split("T")[0];
const fmt = (d) => new Date(d).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" });
const fmtTime = () => new Date().toLocaleTimeString("en-IN", { hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false });
const randColor = (str) => {
  const cols = ["#5b6af5","#00e5b0","#c084fc","#ffb830","#ff5c5c","#38bdf8"];
  let h = 0; for (let c of str) h = (h * 31 + c.charCodeAt(0)) % cols.length;
  return cols[h];
};
const initials = (n) => n ? n.split(" ").map(w => w[0]).join("").slice(0,2).toUpperCase() : "?";

/* ════════════════════════════════════════════════════════════════
   TOAST SYSTEM
════════════════════════════════════════════════════════════════ */
let _toastSetter = null;
const toast = (msg, type = "info") => {
  if (_toastSetter) _toastSetter(prev => {
    const id = Date.now();
    setTimeout(() => _toastSetter(p => p.filter(t => t.id !== id)), 3200);
    return [...prev, { id, msg, type }];
  });
};
const icons = { success: "✅", error: "❌", info: "💡" };

function Toasts() {
  const [toasts, setToasts] = useState([]);
  useEffect(() => { _toastSetter = setToasts; }, []);
  return (
    <div className="toast-wrap">
      {toasts.map(t => (
        <div key={t.id} className={`toast ${t.type}`}>
          <span>{icons[t.type] || "💡"}</span>{t.msg}
        </div>
      ))}
    </div>
  );
}

/* ════════════════════════════════════════════════════════════════
   PROGRESS RING
════════════════════════════════════════════════════════════════ */
function Ring({ pct = 0, color = "#5b6af5", size = 90, label = "" }) {
  const r = 36, c = 50;
  const circ = 2 * Math.PI * r;
  const off = circ - (Math.min(pct, 100) / 100) * circ;
  return (
    <div className="ring-wrap">
      <svg width={size} height={size} viewBox="0 0 100 100">
        <circle cx={c} cy={c} r={r} fill="none" stroke="var(--s3)" strokeWidth="9"/>
        <circle cx={c} cy={c} r={r} fill="none" stroke={color} strokeWidth="9"
          strokeDasharray={circ} strokeDashoffset={off} strokeLinecap="round"
          transform="rotate(-90 50 50)" style={{ transition: "stroke-dashoffset 1.2s ease" }}/>
        <text x="50" y="47" textAnchor="middle" fill="white" fontSize="16"
          fontFamily="Outfit" fontWeight="900">{pct}%</text>
        <text x="50" y="61" textAnchor="middle" fill="var(--t3)" fontSize="9"
          fontFamily="Outfit">{label}</text>
      </svg>
    </div>
  );
}

/* ════════════════════════════════════════════════════════════════
   CLOCK
════════════════════════════════════════════════════════════════ */
function Clock() {
  const [t, setT] = useState(fmtTime());
  useEffect(() => { const id = setInterval(() => setT(fmtTime()), 1000); return () => clearInterval(id); }, []);
  return <span className="mark-time mono">{t}</span>;
}

/* ════════════════════════════════════════════════════════════════
   NOTIFICATION BELL
════════════════════════════════════════════════════════════════ */
function NotifBell({ notifications, onClear }) {
  const [open, setOpen] = useState(false);
  const ref = useRef();
  useEffect(() => {
    const h = (e) => { if (ref.current && !ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener("mousedown", h);
    return () => document.removeEventListener("mousedown", h);
  }, []);
  return (
    <div className="notif-wrap" ref={ref}>
      <button className="notif-btn" onClick={() => setOpen(o => !o)}>
        🔔{notifications.length > 0 && <span className="notif-count">{notifications.length}</span>}
      </button>
      {open && (
        <div className="notif-dd">
          <div className="notif-head flex-between">
            Notifications
            {notifications.length > 0 && <span className="chip" style={{ cursor:"pointer" }} onClick={onClear}>Clear all</span>}
          </div>
          {notifications.length === 0
            ? <div style={{ padding:"20px", textAlign:"center", color:"var(--t3)", fontSize:12 }}>No new notifications</div>
            : notifications.map((n, i) => (
              <div key={i} className="notif-item">
                <div className="notif-item-title">{n.title}</div>
                <div className="notif-item-time">{n.time}</div>
              </div>
            ))
          }
        </div>
      )}
    </div>
  );
}

/* ════════════════════════════════════════════════════════════════
   LOGIN / REGISTER
════════════════════════════════════════════════════════════════ */
function AuthPage({ onAuth }) {
  const [mode, setMode] = useState("login");
  const [f, setF] = useState({ name:"", email:"", password:"", confirm:"" });
  const [err, setErr] = useState({});
  const [loading, setLoading] = useState(false);

  const validate = () => {
    const e = {};
    if (mode === "register" && !f.name.trim()) e.name = "Name is required";
    if (!f.email.includes("@")) e.email = "Enter a valid email";
    if (f.password.length < 6) e.password = "Min 6 characters";
    if (mode === "register" && f.password !== f.confirm) e.confirm = "Passwords don't match";
    return e;
  };

  const submit = () => {
    const e = validate(); setErr(e);
    if (Object.keys(e).length) return;
    setLoading(true);
    setTimeout(() => {
      if (mode === "login") {
        const users = DB.get("users", {});
        const u = users[f.email];
        if (!u) { setErr({ email:"Account not found" }); setLoading(false); return; }
        if (u.password !== f.password) { setErr({ password:"Wrong password" }); setLoading(false); return; }
        DB.set("session", { email:f.email, name:u.name, joinedAt:u.joinedAt });
        onAuth({ email:f.email, name:u.name, joinedAt:u.joinedAt });
        toast("Welcome back, " + u.name + "! 👋", "success");
      } else {
        const users = DB.get("users", {});
        if (users[f.email]) { setErr({ email:"Email already registered" }); setLoading(false); return; }
        const user = { name:f.name, password:f.password, joinedAt:new Date().toISOString() };
        users[f.email] = user;
        DB.set("users", users);
        DB.set("session", { email:f.email, name:f.name, joinedAt:user.joinedAt });
        onAuth({ email:f.email, name:f.name, joinedAt:user.joinedAt });
        toast("Account created! Welcome " + f.name + " 🎉", "success");
      }
      setLoading(false);
    }, 600);
  };

  const inp = (k) => ({ className:"form-input", value:f[k], onChange:e => setF({ ...f, [k]:e.target.value }), onKeyDown:e => e.key === "Enter" && submit() });

  return (
    <div className="login-wrap">
      <div className="login-orb1"/><div className="login-orb2"/>
      <div className="login-card">
        <div className="login-head">
          <div className="login-logo-icon">⚡</div>
          <div className="login-title">Smart <span>Attendance</span></div>
          <div className="login-sub">Tracking System</div>
        </div>
        {mode === "register" && (
          <div className="form-group">
            <label className="form-label">Full Name</label>
            <input {...inp("name")} placeholder="Your full name"/>
            {err.name && <div className="form-err">{err.name}</div>}
          </div>
        )}
        <div className="form-group">
          <label className="form-label">Email Address</label>
          <input {...inp("email")} placeholder="you@example.com"/>
          {err.email && <div className="form-err">{err.email}</div>}
        </div>
        <div className="form-group">
          <label className="form-label">Password</label>
          <input {...inp("password")} type="password" placeholder="••••••••"/>
          {err.password && <div className="form-err">{err.password}</div>}
        </div>
        {mode === "register" && (
          <div className="form-group">
            <label className="form-label">Confirm Password</label>
            <input {...inp("confirm")} type="password" placeholder="••••••••"/>
            {err.confirm && <div className="form-err">{err.confirm}</div>}
          </div>
        )}
        <button className="btn btn-primary btn-lg mt8" onClick={submit} disabled={loading}>
          {loading ? <><div className="spin" style={{ width:16, height:16, borderWidth:2 }}/> Please wait…</> : mode === "login" ? "🚀 Sign In" : "✨ Create Account"}
        </button>
        <div className="switch-link">
          {mode === "login" ? "Don't have an account? " : "Already have an account? "}
          <span onClick={() => { setMode(mode === "login" ? "register" : "login"); setErr({}); }}>
            {mode === "login" ? "Sign Up" : "Sign In"}
          </span>
        </div>
        {mode === "login" && (
          <>
            <div className="divider"><span>demo</span></div>
            <button className="btn btn-ghost" style={{ width:"100%", justifyContent:"center", fontSize:12 }}
              onClick={() => {
                const users = DB.get("users", {});
                if (!users["demo@attendance.dev"]) {
                  users["demo@attendance.dev"] = { name:"Demo Student", password:"demo123", joinedAt:new Date().toISOString() };
                  DB.set("users", users);
                }
                setF({ ...f, email:"demo@attendance.dev", password:"demo123" });
                toast("Demo credentials filled!", "info");
              }}>
              Fill Demo Credentials
            </button>
          </>
        )}
      </div>
    </div>
  );
}

/* ════════════════════════════════════════════════════════════════
   DASHBOARD PAGE
════════════════════════════════════════════════════════════════ */
function Dashboard({ user, records, onMark, notifications, onClearNotif }) {
  const [syncing, setSyncing] = useState(false);
  const td = today();
  const todayRec = records[td];
  const allDays = Object.keys(records).sort().slice(-30);
  const present = allDays.filter(d => records[d] === "present").length;
  const late = allDays.filter(d => records[d] === "late").length;
  const absent = allDays.filter(d => records[d] === "absent").length;
  const total = allDays.length || 1;
  const pct = Math.round(((present + late * 0.7) / total) * 100);

  const weekDays = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
  const weeklyData = weekDays.map((day, i) => {
    const d = new Date(); d.setDate(d.getDate() - (d.getDay() || 7) + i + 1);
    const k = d.toISOString().split("T")[0];
    const s = records[k];
    return { day, present:s==="present"?1:0, late:s==="late"?1:0, absent:s==="absent"?1:0, none:!s?1:0 };
  });

  const handleSync = () => {
    setSyncing(true);
    setTimeout(() => { setSyncing(false); toast("Data synced successfully! 🔄", "success"); }, 1800);
  };

  return (
    <div>
      <div className="ph">
        <div>
          <div className="ph-title">Good {new Date().getHours()<12?"Morning":new Date().getHours()<17?"Afternoon":"Evening"}, {user.name.split(" ")[0]}! 👋</div>
          <div className="ph-sub">{new Date().toLocaleDateString("en-IN",{ weekday:"long", day:"numeric", month:"long", year:"numeric" })}</div>
        </div>
        <div className="flex-row">
          <NotifBell notifications={notifications} onClear={onClearNotif}/>
          <button className="btn btn-ghost" onClick={handleSync} disabled={syncing}>
            <span style={syncing?{ display:"inline-block", animation:"spin .7s linear infinite" }:{}}>🔄</span>
            {syncing?"Syncing…":"Sync DB"}
          </button>
        </div>
      </div>

      <div className="stats-row">
        {[
          { lbl:"Present Days", val:present, color:"var(--a2)", icon:"✅", badge:`${Math.round((present/total)*100)}% of days`, cls:"pill-g" },
          { lbl:"Late Arrivals", val:late, color:"var(--a4)", icon:"⏰", badge:"This month", cls:"pill-y" },
          { lbl:"Absences", val:absent, color:"var(--a3)", icon:"❌", badge:absent>5?"⚠ High":"In range", cls:absent>5?"pill-r":"pill-g" },
          { lbl:"Attendance Rate", val:pct+"%", color:"var(--a1)", icon:"📊", badge:pct>=75?"Good Standing ✓":"Needs Improvement", cls:pct>=75?"pill-g":"pill-r" },
        ].map(s => (
          <div key={s.lbl} className="stat">
            <div className="stat-glow" style={{ background:s.color }}/>
            <div className="stat-lbl">{s.icon} {s.lbl}</div>
            <div className="stat-val" style={{ color:s.color }}>{s.val}</div>
            <span className={`pill ${s.cls}`}>{s.badge}</span>
          </div>
        ))}
      </div>

      <div className="g3">
        <div className="card">
          <div className="card-title">📅 This Week's Overview</div>
          <ResponsiveContainer width="100%" height={190}>
            <BarChart data={weeklyData} barSize={10} barGap={2}>
              <XAxis dataKey="day" tick={{ fill:"var(--t3)", fontSize:11 }} axisLine={false} tickLine={false}/>
              <YAxis hide/>
              <Tooltip contentStyle={{ background:"var(--s2)", border:"1px solid var(--border2)", borderRadius:8, fontSize:12 }} cursor={{ fill:"rgba(255,255,255,.04)" }}/>
              <Bar dataKey="present" name="Present" fill="var(--a2)" radius={[3,3,0,0]}/>
              <Bar dataKey="late" name="Late" fill="var(--a4)" radius={[3,3,0,0]}/>
              <Bar dataKey="absent" name="Absent" fill="var(--a3)" radius={[3,3,0,0]}/>
              <Bar dataKey="none" name="Holiday" fill="var(--s3)" radius={[3,3,0,0]}/>
            </BarChart>
          </ResponsiveContainer>
        </div>

        <div className="card">
          <div className="card-title">🎯 Today's Attendance</div>
          <div className="mark-area">
            <Clock/>
            <div className="mark-date">{fmt(td)}</div>
            <div className={`mark-status ${todayRec?"done":"pending"}`}>
              <span className={`dot ${todayRec?"g":"r"} pulse`}/>
              {todayRec?`Marked as ${todayRec.charAt(0).toUpperCase()+todayRec.slice(1)}`:"Not Marked Yet"}
            </div>
            {!todayRec ? (
              <div style={{ display:"flex", gap:8, justifyContent:"center", flexWrap:"wrap" }}>
                <button className="btn btn-success" onClick={() => onMark("present")}>✅ Present</button>
                <button className="btn" style={{ background:"rgba(255,184,48,.15)", color:"var(--a4)", border:"1px solid rgba(255,184,48,.2)" }} onClick={() => onMark("late")}>⏰ Late</button>
              </div>
            ) : (
              <div style={{ fontSize:12, color:"var(--t3)", marginTop:8 }}>Attendance locked for today</div>
            )}
          </div>
          <div style={{ marginTop:14, display:"flex", justifyContent:"center" }}>
            <Ring pct={pct} label="Overall" size={100}/>
          </div>
        </div>
      </div>

      <div className="card">
        <div className="card-title">📋 Recent Attendance Log</div>
        <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
          {Object.keys(records).sort().reverse().slice(0,7).map(d => {
            const s = records[d];
            const pi = s==="present"?"✅":s==="late"?"⏰":"❌";
            return (
              <div key={d} style={{ display:"flex", alignItems:"center", gap:12, padding:"8px 12px", background:"var(--s2)", borderRadius:8 }}>
                <span style={{ fontSize:15 }}>{pi}</span>
                <span style={{ flex:1, fontSize:13 }}>{fmt(d)}</span>
                <span className="mono" style={{ fontSize:11, color:"var(--t3)" }}>{d}</span>
                <span className={`pill ${s==="present"?"pill-g":s==="late"?"pill-y":"pill-r"}`}>{s}</span>
              </div>
            );
          })}
